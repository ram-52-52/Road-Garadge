{
  "name": "road-garadge-monorepo",
  "version": "1.0.0",
  "description": "Monorepo for Road-Garadge Project",
  "private": true,
  "scripts": {
    "install:backend": "cd backend && npm install",
    "install:frontend": "cd frontend && npm install",
